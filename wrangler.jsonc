    "C:/code/nameverse/.open-next/server-functions/default/.next/server/chunks/code\\nameverse.open-nextserver-functionsdefault\\node_modules\\nextdistcompiled@vercelogyoga.wasm": "./node_modules/next/dist/compiled/@vercel/og/yoga.wasm",
